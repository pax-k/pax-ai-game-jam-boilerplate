  "dependencies": {
    "@ai-game-jam/game": "workspace:*",
    "@ai-game-jam/protocol": "workspace:*",
    "@vitejs/plugin-react": "6.0.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "vite": "8.1.4"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3"
  }
}
