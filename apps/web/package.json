{
  "name": "@ai-game-jam/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bunx vite build",
    "build:itch": "bunx vite build --base ./",
    "check-types": "bunx tsc --noEmit -p tsconfig.json",
